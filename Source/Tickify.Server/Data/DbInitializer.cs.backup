                    Console.WriteLine("✅ Events seeded successfully! (10 events created)");

                    // Seed Ticket Types for each event
                    Console.WriteLine("Seeding Ticket Types...");
                    var ticketTypes = new List<TicketType>();

                    foreach (var evt in events)
                    {
                        if (evt.Title.Contains("Music Festival"))
                        {
                            ticketTypes.AddRange(new[]
                            {
                                new TicketType { EventId = evt.Id, Name = "VIP Pass", Description = "Full access to all stages + VIP lounge", Price = 2500000, Quantity = 500, AvailableQuantity = 350, CreatedAt = DateTime.UtcNow },
                                new TicketType { EventId = evt.Id, Name = "General Admission", Description = "Access to all stages", Price = 1200000, Quantity = 3000, AvailableQuantity = 2100, CreatedAt = DateTime.UtcNow },
                                new TicketType { EventId = evt.Id, Name = "Single Day", Description = "One day access", Price = 500000, Quantity = 1500, AvailableQuantity = 1050, CreatedAt = DateTime.UtcNow }
                            });
                        }
                        else if (evt.Title.Contains("Marathon"))
                        {
                            ticketTypes.AddRange(new[]
                            {
                                new TicketType { EventId = evt.Id, Name = "Full Marathon", Description = "42.195 km", Price = 800000, Quantity = 2000, AvailableQuantity = 1500, CreatedAt = DateTime.UtcNow },
                                new TicketType { EventId = evt.Id, Name = "Half Marathon", Description = "21 km", Price = 500000, Quantity = 3000, AvailableQuantity = 2250, CreatedAt = DateTime.UtcNow },
                                new TicketType { EventId = evt.Id, Name = "10K Fun Run", Description = "10 km", Price = 300000, Quantity = 5000, AvailableQuantity = 3750, CreatedAt = DateTime.UtcNow }
                            });
                        }
                        else if (evt.Title.Contains("Tech Summit"))
                        {
                            ticketTypes.AddRange(new[]
                            {
                                new TicketType { EventId = evt.Id, Name = "Conference Pass", Description = "2-day full access", Price = 3000000, Quantity = 600, AvailableQuantity = 360, CreatedAt = DateTime.UtcNow },
                                new TicketType { EventId = evt.Id, Name = "Workshop Bundle", Description = "Conference + workshops", Price = 4500000, Quantity = 200, AvailableQuantity = 120, CreatedAt = DateTime.UtcNow },
                                new TicketType { EventId = evt.Id, Name = "Student", Description = "Student discount ticket", Price = 1500000, Quantity = 200, AvailableQuantity = 120, CreatedAt = DateTime.UtcNow }
                            });
                        }
                        else
                        {
                            ticketTypes.AddRange(new[]
                            {
                                new TicketType { EventId = evt.Id, Name = "Standard", Description = "Regular admission", Price = 500000, Quantity = (int)(evt.TotalTickets * 0.7), AvailableQuantity = (int)(evt.AvailableTickets * 0.7), CreatedAt = DateTime.UtcNow },
                                new TicketType { EventId = evt.Id, Name = "Premium", Description = "Premium experience with extras", Price = 1000000, Quantity = (int)(evt.TotalTickets * 0.3), AvailableQuantity = (int)(evt.AvailableTickets * 0.3), CreatedAt = DateTime.UtcNow }
                            });
                        }
                    }

                    await context.TicketTypes.AddRangeAsync(ticketTypes);
                    await context.SaveChangesAsync();

                    Console.WriteLine($"✅ Ticket Types seeded successfully! ({ticketTypes.Count} ticket types)");
                }

                // Seed Sample Bookings and Reviews
                if (!await context.Bookings.AnyAsync())
                {
                    Console.WriteLine("Seeding Sample Bookings and Reviews...");

                    var customers = await context.Users
                        .Join(context.UserRoles, u => u.Id, ur => ur.UserId, (u, ur) => new { u, ur })
                        .Join(context.Roles, x => x.ur.RoleId, r => r.Id, (x, r) => new { x.u, r })
                        .Where(x => x.r.Name == "Customer")
                        .Select(x => x.u)
                        .ToListAsync();

                    var events = await context.Events.Include(e => e.TicketTypes).ToListAsync();
                    var bookings = new List<Booking>();
                    var tickets = new List<Ticket>();
                    var reviews = new List<Review>();

                    var random = new Random();

                    // Create bookings for past events (completed with reviews)
                    foreach (var customer in customers.Take(3))
                    {
                        var pastEvent = events.FirstOrDefault(e => e.StartDate > DateTime.UtcNow.AddDays(-30) && e.StartDate < DateTime.UtcNow);
                        if (pastEvent != null && pastEvent.TicketTypes.Any())
                        {
                            var ticketType = pastEvent.TicketTypes.First();
                            var quantity = random.Next(1, 3);

                            var booking = new Booking
                            {
                                UserId = customer.Id,
                                EventId = pastEvent.Id,
                                BookingDate = DateTime.UtcNow.AddDays(-25),
                                TotalAmount = ticketType.Price * quantity,
                                PaymentStatus = "Completed",
                                PaymentMethod = "VNPay",
                                BookingStatus = "Confirmed",
                                TransactionId = $"TXN{random.Next(100000, 999999)}",
                                CreatedAt = DateTime.UtcNow.AddDays(-25)
                            };
                            bookings.Add(booking);

                            // Add review
                            reviews.Add(new Review
                            {
                                EventId = pastEvent.Id,
                                UserId = customer.Id,
                                Rating = random.Next(4, 6),
                                Comment = new[] {
                                    "Amazing experience! Highly recommended.",
                                    "Great event, well organized and fun!",
                                    "Loved every moment, will definitely come again.",
                                    "Fantastic atmosphere and great performances!"
                                }[random.Next(4)],
                                CreatedAt = DateTime.UtcNow.AddDays(-20)
                            });
                        }
                    }

                    // Create upcoming bookings
                    for (int i = 0; i < customers.Count; i++)
                    {
                        var upcomingEvents = events.Where(e => e.StartDate > DateTime.UtcNow).OrderBy(e => e.StartDate).Take(2);
                        foreach (var upcomingEvent in upcomingEvents)
                        {
                            if (upcomingEvent.TicketTypes.Any())
                            {
                                var ticketType = upcomingEvent.TicketTypes.ElementAt(random.Next(upcomingEvent.TicketTypes.Count));
                                var quantity = random.Next(1, 4);

                                var booking = new Booking
                                {
                                    UserId = customers[i].Id,
                                    EventId = upcomingEvent.Id,
                                    BookingDate = DateTime.UtcNow.AddDays(-random.Next(1, 10)),
                                    TotalAmount = ticketType.Price * quantity,
                                    PaymentStatus = "Completed",
                                    PaymentMethod = random.Next(2) == 0 ? "VNPay" : "MoMo",
                                    BookingStatus = "Confirmed",
                                    TransactionId = $"TXN{random.Next(100000, 999999)}",
                                    CreatedAt = DateTime.UtcNow.AddDays(-random.Next(1, 10))
                                };
                                bookings.Add(booking);
                            }
                        }
                    }

                    await context.Bookings.AddRangeAsync(bookings);
                    await context.SaveChangesAsync();

                    // Create tickets for bookings
                    foreach (var booking in bookings)
                    {
                        var ticketType = await context.TicketTypes.FirstAsync(tt => tt.EventId == booking.EventId);
                        var quantity = (int)(booking.TotalAmount / ticketType.Price);

                        for (int i = 0; i < quantity; i++)
                        {
                            tickets.Add(new Ticket
                            {
                                BookingId = booking.Id,
                                TicketTypeId = ticketType.Id,
                                UserId = booking.UserId,
                                QRCode = Guid.NewGuid().ToString(),
                                Status = "Active",
                                IsCheckedIn = booking.BookingStatus == "Completed",
                                CreatedAt = booking.CreatedAt
                            });
                        }
                    }

                    await context.Tickets.AddRangeAsync(tickets);
                    await context.Reviews.AddRangeAsync(reviews);
                    await context.SaveChangesAsync();

                    Console.WriteLine($"✅ Bookings seeded! ({bookings.Count} bookings, {tickets.Count} tickets, {reviews.Count} reviews)");
                }

                Console.WriteLine("\n🎉 Database seeding completed successfully!");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"❌ Error seeding database: {ex.Message}");
                Console.WriteLine($"   Stack trace: {ex.StackTrace}");
                throw;
            }
        }
    }
}
