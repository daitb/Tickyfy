                    var organizerRole = await context.Roles.FirstAsync(r => r.Name == "Organizer");

                    var userRoles = new List<UserRole>
                    {
                        // Customers (first 4 users)
                        new UserRole { UserId = users[0].Id, RoleId = customerRole.Id, AssignedAt = DateTime.UtcNow },
                        new UserRole { UserId = users[1].Id, RoleId = customerRole.Id, AssignedAt = DateTime.UtcNow },
