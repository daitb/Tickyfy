                        new UserRole { UserId = users[8].Id, RoleId = organizerRole.Id, AssignedAt = DateTime.UtcNow }
                    };

                    await context.UserRoles.AddRangeAsync(userRoles);
                    await context.SaveChangesAsync();

                    Console.WriteLine("✅ Sample users created!");
                    Console.WriteLine($"   Customers: 4 users (customer@example.com, jane.smith@example.com, mike.johnson@example.com, sarah.wilson@example.com)");
                    Console.WriteLine($"   Staff: 2 users (staff@tickify.com, support@tickify.com)");
                    Console.WriteLine($"   Organizers: 3 users (organizer1-3@example.com)");
                    Console.WriteLine($"   Default Password: Customer@123, Staff@123, or Organizer@123");
                }

                // Seed Organizers
                if (!await context.Organizers.AnyAsync())
                {
                    Console.WriteLine("Seeding Organizers...");

                    var organizerUsers = await context.Users
                        .Join(context.UserRoles, u => u.Id, ur => ur.UserId, (u, ur) => new { u, ur })
                        .Join(context.Roles, x => x.ur.RoleId, r => r.Id, (x, r) => new { x.u, r })
                        .Where(x => x.r.Name == "Organizer")
                        .Select(x => x.u)
                        .ToListAsync();

                    var staffUser = await context.Users.FirstOrDefaultAsync(u => u.Email == "staff@tickify.com");

                    var organizers = new List<Organizer>
